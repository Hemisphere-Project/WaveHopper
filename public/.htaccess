# WaveHopper — Apache / LiteSpeed shared-hosting config.
# Plain Nginx ignores this file; ask the host for equivalent rules in that case.

# --- Correct MIME types ----------------------------------------------------
AddType application/manifest+json .webmanifest
AddType application/javascript    .js
AddType application/json          .json
AddType application/vnd.apple.mpegurl .m3u8
AddType font/woff2                .woff2

# --- Cache headers ---------------------------------------------------------
<IfModule mod_headers.c>
    # Service worker must NOT be long-cached or updates will lag.
    <FilesMatch "^sw\.js$">
        Header set Cache-Control "max-age=0, must-revalidate, no-cache"
    </FilesMatch>

    # The station list is small and frequently rebuilt — let the SW handle freshness.
    <FilesMatch "^stations\.json$">
        Header set Cache-Control "max-age=0, must-revalidate"
    </FilesMatch>

    # The HTML shell drives SW registration; keep it short-lived too.
    <FilesMatch "^(index\.html)?$">
        Header set Cache-Control "max-age=300, must-revalidate"
    </FilesMatch>

    # Hashed-or-stable assets (icons, fonts, vendored libs) can cache long.
    <FilesMatch "\.(png|ico|woff2|woff)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
</IfModule>

# --- Gzip text assets ------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/manifest+json image/svg+xml
</IfModule>

# --- SPA-ish fallback is NOT needed; every URL is a real file. -------------
